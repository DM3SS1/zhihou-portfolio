---
import { Image } from 'astro:assets';

// 导入图片
// 假设顺序是：
// 左列：img1, img3
// 右列：img2, img4
import img1 from '/src/assets/imgs/EBO/1.png';
import img2 from '/src/assets/imgs/EBO/2.png';
import img3 from '/src/assets/imgs/EBO/3.png';
import img4 from '/src/assets/imgs/EBO/4.png';

const { id } = Astro.props; // 必须有这一行来接收 index 传过来的 id
---

<section class="project-section" id={id}>
    <!-- 左侧：文本信息 -->
    <div class="left">
        <div class="title font-title2">
            <span class="title-symbol"></span>项目工作内容
            <span class="title-description font-text color-green">ONLINE TEACHING SYSTEM</span>
        </div>
        
        <div class="page-item">
            <div class="item-header font-subtext text-loose text-bold color-gy3 uppercase">
                <span class="status-dot"></span>vector component library
            </div>
            <div class="item-content-wrapper">
                <div class="item-title font-title-caption text-bold color-gy1">
                    构建 EBO 矢量图库 (组件库)
                </div>
                <div class="item-content font-text color-gy2">
                    为公司 EBO 软件产品制作等距视角 (2.5D)
                    矢量图库，实现暖通、灯控、管道等设备的组件化复用，有效提升图形资源的开发效率与维护一致性。
                </div>
            </div>
        </div>

        <div class="page-item">
            <div class="item-header font-subtext text-loose text-bold color-gy3 uppercase">
                <span class="status-dot"></span>Projects Support
            </div>
            <div class="item-content-wrapper">
                <div class="item-title font-title-caption text-bold color-gy1">
                    EBO 项目支持 (定制化)
                </div>
                <div class="item-content font-text color-gy2">
                    负责页面的 UI 设计与前端实现，输出可直接在 EBO 中使用的 TGML
                    页面文件。实现运行状态的实时可视化绑定，增强系统监控的交互性。
                </div>
            </div>
        </div>

        <!-- 如果 tags 暂时不需要显示，可以直接注释掉或保留 display: none -->
        <div class="tags" style="display: none;">
            <span class="tag font-subtext color-gy3 uppercase round-8">UCD METHODOLOGY</span>
            <span class="tag font-subtext color-gy3 uppercase round-8">CROSS-PLATFORM</span>
        </div>
    </div>

    <!-- 右侧：瀑布流图片组 -->
    <div class="right">
        <!-- 
           Masonry 布局策略：
           分为左右两列 (column)，图片在列内垂直堆叠。
           Image 组件优化：
           sizes 计算逻辑：
           - Mobile (640px以下): 单列，占 100vw
           - Tablet (1024px以下): 右侧占全屏，内部两列，每列约 50vw
           - Desktop: 右侧占 2/3 屏，内部两列，每列约 33vw
        -->
        
        <!-- 第一列 -->
        <div class="gallery-column">
            <Image 
                src={img1} 
                alt="EBO 矢量组件预览" 
                class="gallery-img round-8"
                widths={[400, 800]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            />
            <Image 
                src={img3} 
                alt="EBO 管道组件细节" 
                class="gallery-img round-8"
                widths={[400, 800]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            />
        </div>

        <!-- 第二列 -->
        <div class="gallery-column">
            <Image 
                src={img2} 
                alt="TGML 页面展示" 
                class="gallery-img round-8"
                widths={[400, 800]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            />
            <Image 
                src={img4} 
                alt="实时监控界面" 
                class="gallery-img round-8"
                widths={[400, 800]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
            />
        </div>
    </div>
</section>

<style>
    /* === 布局基础 === */
    .project-section {
        display: flex;
        gap: var(--space-64);
        width: 100%;
        margin-bottom: var(--space-80);
    }

    .left {
        flex: 0 0 calc((100% - var(--space-64)) / 12 * 4);
        min-width: 0;
    }

    .right {
        flex: 0 0 calc((100% - var(--space-64)) / 12 * 8);
        box-sizing: border-box;
        
        /* 右侧内部布局 */
        display: flex;
        gap: var(--space-16);
        align-items: flex-start; /* 关键：防止列高度被强制拉伸 */
    }

    /* === 左侧文本样式 === */
    .title { margin-bottom: var(--space-56); }
    .title-symbol {
        display: block; width: 32px; height: 4px; 
        background: var(--color-green); margin-bottom: var(--space-16);
    }
    .title-description { margin-top: var(--space-4); display: none; }

    .item-header { display: flex; gap: var(--space-8); align-items: center; }
    .status-dot {
        width: 6px; height: 6px; background-color: var(--color-green); 
        border-radius: 50%; flex-shrink: 0;
    }

    .item-content-wrapper {
        display: flex; flex-direction: column; gap: var(--space-16);
        border-left: 1px solid var(--color-gy5); padding-left: var(--space-12);
        margin-top: var(--space-8); margin-bottom: var(--space-48);
    }
    .item-content { overflow-wrap: anywhere; line-height: 1.6; }

    /* === 右侧图片样式 === */
    .gallery-column {
        /* 
           flex: 1 表示两列等分剩余空间。
           设置 min-width: 0 防止图片过宽导致 flex 布局溢出 
        */
        flex: 1;
        min-width: 0; 
        
        display: flex;
        flex-direction: column;
        gap: var(--space-16);
    }

    .gallery-img {
        display: block;
        width: 100%;
        height: auto; /* 瀑布流的关键：高度自适应 */
        box-shadow: var(--shadow-m);
        transition: var(--transition);
        background-color: #f0f0f0; /* 加载前的占位色 */
    }

    .gallery-img:hover {
        transform: scale(1.02) translateY(-0.25rem);
        box-shadow: var(--shadow-l);
    }

    /* === 响应式 === */
    @media (max-width: 1024px) {
        .project-section {
            flex-direction: column;
            gap: var(--space-40);
        }
        .left, .right {
            flex: 0 0 100%;
        }
    }

    @media (max-width: 640px) {
        .right {
            flex-direction: column; /* 整个右侧变为垂直单列 */
        }
        /* 
           在手机端，原本的两列 gallery-column 现在垂直堆叠。
           这会造成 1,3 在上面，2,4 在下面的视觉顺序。
           对于纯图片展示这是可以接受的。
        */
        .gallery-column {
            width: 100%;
        }
    }
</style>