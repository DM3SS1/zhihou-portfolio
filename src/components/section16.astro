---
const { id } = Astro.props; // 必须有这一行来接收 index 传过来的 id
import { Image } from "astro:assets";
// 假设你的图片路径是 src/assets/imgs/covers/painting_bg.png
// 如果图片在 public 文件夹，请保持原样引用，但建议放在 src 下以利用 Astro 优化
import bgImage from "/src/assets/imgs/covers/painting_bg.jpg";
---

<section class="art-cover-wrapper" id={id}>
    <!-- 背景动态光晕 (装饰性元素隐藏) -->
    <div class="ambient-light digital-light" aria-hidden="true"></div>
    <div class="ambient-light traditional-light" aria-hidden="true"></div>

    <!-- 视觉层结构 -->
    <div class="visual-layer" aria-hidden="true">
        <!-- 1. 底层：Astro 优化后的背景图 -->
        <Image
            src={bgImage}
            alt="Art Background"
            class="painting-bg-img"
            width={1920}
            quality={100}
            fetchpriority="high"
        />

        <!-- 2. 顶层：噪点纹理 -->
        <div class="noise-overlay"></div>
    </div>

    <!-- 内容区域 -->
    <div class="cover-content">
        <div class="intro-text text-light">
            <!-- <span class="chapter-no">CHAPTER 02</span> -->
            <span class="divider-line"></span>
            <span class="chapter-desc">Paintings</span>
            <span class="divider-line"></span>
        </div>

        <h1 class="main-title">绘画</h1>

        <p class="description text-light">
            探索光影与笔触的边界。从屏幕上的像素构建，到纸张上的墨迹流淌。
        </p>

        <!-- 分类导航 -->
        <nav class="category-nav">
            <a href="#digital" class="nav-item theme-digital">
                <span class="arrow">→</span>
                <div class="text-group">
                    <span class="title">数字绘画</span>
                    <span class="sub">Matte Painting / 概念设计</span>
                </div>
            </a>

            <a href="#traditional" class="nav-item theme-traditional">
                <span class="arrow">→</span>
                <div class="text-group">
                    <span class="title">传统绘画</span>
                    <span class="sub">素描 / 速写</span>
                </div>
            </a>
        </nav>
    </div>
</section>

<style>
    /* === 变量定义 === */
    :root {
        --c-digital: #0099ff;
        --c-traditional: #3dcd58;
        /* 压缩后的 SVG 噪点，减少 CSS 体积 */
        --noise-bg: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.5' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    }

    /* === 主容器 === */
    .art-cover-wrapper {
        position: relative;
        /* width: 100%; */
        /* height: 100vh; */
        height: 100dvh; /* 核心优化：适配移动端动态高度 */
        /* min-height: 600px; */
        background-color: #000000;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* === 视觉层 (背景图 + 噪点 + 光晕) === */
    .visual-layer {
        position: absolute;
        inset: 0;
        z-index: 1;
        isolation: isolate; /* 建立新的混合模式上下文 */
        pointer-events: none;
        filter: brightness(65%);
    }

    /* Astro 图片样式 */
    .painting-bg-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 1;
        mask: radial-gradient(
            circle at center,
            rgba(0, 0, 0, 0.8) 0%,
            rgba(0, 0, 0, 0.25) 120%
        );
    }

    .noise-overlay {
        position: absolute;
        inset: 0;
        z-index: 2;
        background: radial-gradient(
                circle at center,
                rgba(255, 255, 255, 0.8) 0%,
                transparent 70%
            ),
            var(--noise-bg);
        filter: contrast(200%) brightness(100%); /* 调整亮度避免过黑 */
        opacity: 0.35; /* 调整为更细腻的质感 */
        mix-blend-mode: multiply;
    }

    /* 背景动态光晕 */
    .ambient-light {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.3;
        z-index: 2; /* 在背景图之上，噪点之下或之上均可 */
        animation: breathe 5s infinite ease-in-out alternate;
        mix-blend-mode: screen; /* screen 模式在深色背景下表现更好 */
        will-change: transform, opacity; /* 性能优化 */
    }

    .digital-light {
        top: -15%;
        left: -15%;
        width: 60vw;
        height: 60vw;
        background: radial-gradient(
            closest-side,
            var(--c-digital),
            transparent
        );
    }

    .traditional-light {
        bottom: -15%;
        right: -15%;
        width: 60vw;
        height: 60vw;
        background: radial-gradient(
            closest-side,
            var(--c-traditional),
            transparent
        );
        animation-delay: -2.5s;
    }

    @keyframes breathe {
        0% {
            transform: scale(1) translate(5% -5%);
            opacity: 0.2;
        }
        100% {
            transform: scale(1.2);
            opacity: 0.4;
        }
    }

    /* === 内容区域 === */
    .cover-content {
        position: relative;
        z-index: 10;
        text-align: center;
        padding: 0  var(--space-20);
        width: 100%;
        max-width: 800px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4rem;
    }

    .intro-text {
        display: flex;
        align-items: center;
        gap:  var(--space-16);
        font-size: 2.375rem;
        letter-spacing: 0.15em;
        color: var(--color-wh3);
        text-transform: uppercase;
        filter: drop-shadow(0px 0px 16px rgba(0, 0, 0, 1));
    }

    .divider-line {
        width: 48px;
        height: 2px;
        background-color: var(--color-wh4);
    }

    .main-title {
        /* 使用 clamp 实现丝滑的响应式字体 */
        font-size: clamp(4rem, 15vw, 12rem);
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.03em;
        /* 文字渐变 */
        background: linear-gradient(
            to bottom right,
            #fff 10%,
            rgba(255, 255, 255, 0.55)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        color: white; /* 降级回退 */
        margin: 0;
        filter: drop-shadow(0px 0px 16px rgba(0, 0, 0, 0.8));
        
    }

    .description {
        font-size: 1.25rem;
        line-height: 1.6;
        color: var(--color-wh1);
        filter: drop-shadow(0px 0px 12px rgba(0, 0, 0, 0.8));
        /* max-width: 500px; */
        /* margin: 0 auto 5rem auto; */
    }

    /* === 导航卡片 === */
    .category-nav {
        width: 100%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap:  var(--space-40);
    }

    .nav-item {
        position: relative;
        display: flex;
        align-items: center;
        gap: var(--space-24);
        padding: var(--space-24) var(--space-32);

        text-decoration: none;
        color: #fff;
        background: color-mix(
            in oklab,
            var(--theme-color) 25%,
            rgba(255, 255, 255, 0.05)
        );
        border: 1px solid color-mix(in oklab, var(--theme-color) 50%, transparent);
        box-shadow: 0 8px 32px
            color-mix(in oklab, var(--theme-color) 25%, transparent);
        border-radius: 16px;
        backdrop-filter: blur(4px);

        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        overflow: hidden;
    }

    /* 内部文本 */
    .text-group {
        display: flex;
        flex-direction: column;
        text-align: left;
    }
    .nav-item .title {
        font-size: 1.25rem;
        font-weight: 700;
        letter-spacing: 0.02em;
    }
    .nav-item .sub {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.55);
        margin-top: var(--space-8);
        transition: color 0.3s;
    }
    .nav-item .arrow {
        font-size: 1.4rem;
        transition: transform 0.3s ease;
        color: rgba(255, 255, 255, 0.35);
    }

    /* === 交互状态 (Hover) === */

    /* 定义 CSS 变量方便局部作用域调用 */
    .theme-digital {
        --theme-color: var(--c-digital);
    }
    .theme-traditional {
        --theme-color: var(--c-traditional);
    }

    /* .nav-item:hover {
        background: color-mix(in oklab, var(--theme-color) 10%, rgba(255,255,255,0.05));
        border-color: color-mix(in oklab, var(--theme-color) 50%, transparent);
        box-shadow: 0 8px 32px color-mix(in oklab, var(--theme-color) 15%, transparent);
        transform: translateY(-2px);
    } */

    .nav-item:hover {
        background: color-mix(
            in oklab,
            var(--theme-color) 40%,
            rgba(255, 255, 255, 0.05)
        );
        box-shadow: 0 8px 32px
            color-mix(in oklab, var(--theme-color) 60%, transparent);
        transform: translateY(-2px);
    }

    .nav-item:hover .arrow {
        transform: translateX(6px);
        color: var(--theme-color);
    }

    .nav-item .arrow {
        /* transform: translateX(6px); */
        color: var(--theme-color);
    }

    .nav-item:hover .sub {
        color: rgba(255, 255, 255, 0.8);
    }

    /* === 响应式适配 === */
    @media (max-width: 768px) {
        .cover-content {
            gap: 2rem;
        }
        .category-nav {
            grid-template-columns: 1fr; /* 移动端改为单列 */
            gap: var(--space-24);
        }

        .intro-text {
            
            font-size: 2rem;
        }

        .main-title {
            /* margin-bottom: 1.5rem; */
        }

        .description {
            /* font-size: 1rem; */
            margin-bottom: 3rem;
        }

        .nav-item {
            padding: var(--space-16) var(--space-24);
        }
    }
</style>
